{{ 'section-tier-showcase.css' | asset_url | stylesheet_tag }}

<section
  class="tier-showcase"
  style="background-color: {{ section.settings.background_color }};"
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div
      class="tier-showcase__header"
      style="text-align: {{ section.settings.header_alignment }};"
    >
      {%- if section.settings.heading != blank -%}
        <h2
          class="tier-showcase__heading"
          style="color: {{ section.settings.heading_color }};"
        >
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p
          class="tier-showcase__subheading"
          style="color: {{ section.settings.subheading_color }};"
        >
          {{ section.settings.subheading | newline_to_br }}
        </p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- for block in section.blocks -%}
    <div
      id="TierShowcase-{{ block.id }}"
      class="tier-showcase__item"
      style="--tier-card-max-width: {{ block.settings.card_max_width }}px; --tier-card-position: {{ block.settings.card_position }}; --tier-card-position-y: {{ block.settings.card_position_y }};"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.background_image != blank -%}
        <div class="tier-showcase__bg">
          {{
            block.settings.background_image
            | image_url: width: 3840
            | image_tag:
              loading: 'lazy',
              widths: '450, 750, 1100, 1500, 1920, 2400, 3840',
              sizes: '100vw',
              alt: block.settings.background_image.alt | default: block.settings.tier_name
          }}
          {%- if block.settings.overlay_opacity > 0 -%}
            <div
              class="tier-showcase__bg-overlay"
              style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
            ></div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div
        class="tier-showcase__card"
        style="
          background-color: {{ block.settings.card_bg_color }};
          color: {{ block.settings.card_text_color }};
          padding: {{ block.settings.card_padding }}px;
          border-radius: {{ block.settings.card_border_radius }}px;
          text-align: {{ block.settings.card_text_alignment }};
          min-height: {{ block.settings.card_min_height }}px;
        "
      >
        {%- if block.settings.tier_name != blank -%}
          <h3 class="tier-showcase__name">{{ block.settings.tier_name }}</h3>
        {%- endif -%}

        {%- if block.settings.amount != blank -%}
          <div class="tier-showcase__price">
            {%- if block.settings.currency != blank -%}
              <span class="tier-showcase__currency">{{ block.settings.currency }}</span>
            {%- endif -%}
            <span class="tier-showcase__amount">{{ block.settings.amount }}</span>
            {%- if block.settings.price_suffix != blank -%}
              <span class="tier-showcase__suffix">{{ block.settings.price_suffix }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <div class="tier-showcase__description rte">{{ block.settings.description }}</div>
        {%- endif -%}

        {%- if block.settings.show_divider and block.settings.features != blank -%}
          <hr class="tier-showcase__divider">
        {%- endif -%}

        {%- if block.settings.features != blank -%}
          <ul class="tier-showcase__features">
            {%- assign features = block.settings.features | newline_to_br | split: '<br />' -%}
            {%- for feature in features -%}
              {%- assign trimmed = feature | strip -%}
              {%- if trimmed != blank -%}
                <li>{{ trimmed }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if block.settings.button_label != blank -%}
          <a
            class="tier-showcase__button tier-showcase__button--{{ block.settings.button_style }}"
            href="{{ block.settings.button_link | default: '#' }}"
            {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
          >
            {{ block.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Tier Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "info": "Press Enter for line breaks"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#034325"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#034325"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#EEEEEE"
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        {
          "type": "header",
          "content": "Background image"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 0
        },
        {
          "type": "header",
          "content": "Card position"
        },
        {
          "type": "range",
          "id": "card_position",
          "label": "Card horizontal position",
          "info": "0 = left edge, 50 = center, 100 = right edge. Slider basis is the card max width.",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 50
        },
        {
          "type": "range",
          "id": "card_position_y",
          "label": "Card vertical position",
          "info": "0 = top, 50 = middle, 100 = bottom. Slider basis is the section height.",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 50
        },
        {
          "type": "header",
          "content": "Card style"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card background",
          "default": "#2a2116"
        },
        {
          "type": "color",
          "id": "card_text_color",
          "label": "Card text color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "card_max_width",
          "label": "Card max width",
          "min": 280,
          "max": 640,
          "step": 20,
          "unit": "px",
          "default": 460
        },
        {
          "type": "range",
          "id": "card_min_height",
          "label": "Card minimum height",
          "info": "0 = auto (sizes to content). Use to keep tiers visually consistent.",
          "min": 0,
          "max": 800,
          "step": 20,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "card_padding",
          "label": "Card padding",
          "min": 16,
          "max": 64,
          "step": 4,
          "unit": "px",
          "default": 32
        },
        {
          "type": "range",
          "id": "card_border_radius",
          "label": "Card border radius",
          "min": 0,
          "max": 32,
          "step": 2,
          "unit": "px",
          "default": 10
        },
        {
          "type": "select",
          "id": "card_text_alignment",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "tier_name",
          "label": "Tier name",
          "default": "The Pioneer"
        },
        {
          "type": "text",
          "id": "currency",
          "label": "Currency symbol",
          "default": "P"
        },
        {
          "type": "text",
          "id": "amount",
          "label": "Amount",
          "default": "20,000"
        },
        {
          "type": "text",
          "id": "price_suffix",
          "label": "Price suffix",
          "info": "e.g. /quarter"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "show_divider",
          "label": "Show divider above features",
          "default": true
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Features",
          "info": "One per line — rendered as bulleted list"
        },
        {
          "type": "header",
          "content": "Call to action"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "ADD TO CART"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "outline", "label": "Outline (border)" },
            { "value": "filled", "label": "Filled" },
            { "value": "ghost", "label": "Ghost (text only)" }
          ],
          "default": "outline"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tier Showcase",
      "blocks": [
        { "type": "tier" },
        { "type": "tier" }
      ]
    }
  ]
}
{% endschema %}
