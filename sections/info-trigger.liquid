{%- comment -%}
Interactive expanding columns (single file)
Desktop: horizontal row; clicking expands one column (accordion style).
Mobile (<1025px): stacked; clicking expands height.
{%- endcomment -%}

{%- liquid
  assign section_id = section.id
  assign expanded_index = 0
-%}

<div id="InteractiveColumns-{{ section_id }}" class="interactive-columns section-{{ section_id }}">
  {%- if section.settings.heading != blank -%}
    <div class="interactive-columns__header page-width">
      <h2 class="interactive-columns__title">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="interactive-columns__wrap">
    <div class="main" data-columns>
      {%- for block in section.blocks -%}
        {%- assign img = block.settings.image -%}
        <div
          class="column{% if forloop.first %} expanded{% endif %}"
          data-column
          {{ block.shopify_attributes }}
          style="
            {% if img %}
              --bg-image: url('{{ img | image_url: width: 1600 }}');
            {% endif %}
          "
        >
          <button
            type="button"
            class="column__btn"
            data-column-trigger
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="ColPanel-{{ section_id }}-{{ forloop.index }}"
          >
            <span class="visually-hidden">
              {{ block.settings.heading | default: 'Column' | escape }}
            </span>
          </button>

          <div
            class="inner-element{% if forloop.first %} active{% endif %}"
            id="ColPanel-{{ section_id }}-{{ forloop.index }}"
            role="group"
            aria-label="{{ block.settings.heading | escape }}"
          >
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.link_label != blank %}
              <p class="inner-element__link">
                <a
                  {% if block.settings.link_url != blank %}
                    href="{{ block.settings.link_url }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  class="interactive-columns__link"
                >
                  {{ block.settings.link_label | escape }}
                </a>
              </p>
            {% endif %}
          </div>

          {% if block.settings.icon_text != blank %}
            <div class="icons" aria-hidden="true">
              {{ block.settings.icon_text }}
            </div>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
#InteractiveColumns-{{ section_id }} {
  --expand-width-desktop: {{ section.settings.desktop_expanded_percent }}%;
  --collapsed-width-desktop: calc((100% - var(--expand-width-desktop)) / ({{ section.blocks.size | at_least: 1 }} - 1));
  --mobile-collapsed-h: {{ section.settings.mobile_collapsed_height }}px;
  --mobile-expanded-h: {{ section.settings.mobile_expanded_height }}px;
  --transition-time: {{ section.settings.transition_duration | divided_by: 1000.0 }}s;
  --overlay-color: rgba(0,0,0,0.5);
  --radius: 10px;
  --content-offset-desktop: 100px;
  font-family: inherit;
}

#InteractiveColumns-{{ section_id }} .interactive-columns__header {
  margin-bottom: 1.5rem;
  text-align: center;
}

#InteractiveColumns-{{ section_id }} .interactive-columns__title {
  margin: 0;
}

#InteractiveColumns-{{ section_id }} .interactive-columns__wrap {
  width: 100%;
  overflow: hidden;
}

#InteractiveColumns-{{ section_id }} .main {
  display: flex;
  flex-direction: row;
  width: 100%;
  min-height: 380px;
  gap: 0;
  border-radius: var(--radius);
  overflow: hidden;
  position: relative;
}

#InteractiveColumns-{{ section_id }} .column {
  background: #444 center/cover no-repeat;
  {% if section.blocks.size > 0 %}
  width: calc((100% - var(--expand-width-desktop)) / ({{ section.blocks.size }} - 1));
  {% else %}
  width: 100%;
  {% endif %}
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  cursor: pointer;
  transition: width var(--transition-time) ease, height var(--transition-time) ease;
  isolation: isolate;
  background-image: var(--bg-image);
  overflow: hidden;
}

#InteractiveColumns-{{ section_id }} .column:first-child {
  border-radius: var(--radius) 0 0 var(--radius);
}
#InteractiveColumns-{{ section_id }} .column:last-child {
  border-radius: 0 var(--radius) var(--radius) 0;
}

#InteractiveColumns-{{ section_id }} .column.expanded {
  width: var(--expand-width-desktop);
}

#InteractiveColumns-{{ section_id }} .column.expanded::after {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--overlay-color);
  z-index: 0;
}

#InteractiveColumns-{{ section_id }} .column__btn {
  position: absolute;
  inset: 0;
  background: transparent;
  border: 0;
  padding: 0;
  margin: 0;
  cursor: pointer;
  z-index: 3;
  font: inherit;
  color: inherit;
}

#InteractiveColumns-{{ section_id }} .inner-element {
  position: absolute;
  left: 0;
  bottom: var(--content-offset-desktop);
  padding: 20px;
  opacity: 0;
  transition: opacity .35s ease .0s;
  z-index: 2;
  max-width: 520px;
}

#InteractiveColumns-{{ section_id }} .inner-element.active {
  opacity: 1;
  transition: opacity .45s ease .25s;
}

#InteractiveColumns-{{ section_id }} .inner-element h2 {
  margin: 0 0 .6rem;
  color: #fff;
  font-size: 24px;
  line-height: 1.2;
}

#InteractiveColumns-{{ section_id }} .inner-element p {
  margin: 0 0 .75rem;
  color: #fff;
  font-weight: 300;
  font-size: 16px;
  line-height: 1.45;
}

#InteractiveColumns-{{ section_id }} .inner-element__link a {
  color: #fff;
  text-decoration: underline;
}

#InteractiveColumns-{{ section_id }} .icons {
  position: absolute;
  bottom: 20px;
  left: 18px;
  font-size: 20px;
  padding: 20px;
  background: #fff;
  z-index: 2;
  border-radius: 50%;
  height: 40px;
  width: 40px;
  display:flex;
  justify-content:center;
  align-items:center;
  color:#111;
  font-weight: 600;
  pointer-events: none;
  box-shadow: 0 4px 10px rgba(0,0,0,.25);
}

/* Mobile / Tablet */
@media (max-width: 1024px) {
  #InteractiveColumns-{{ section_id }} .main {
    flex-direction: column;
    min-height: 0;
  }

  #InteractiveColumns-{{ section_id }} .column,
  #InteractiveColumns-{{ section_id }} .column.expanded {
    width: 100% !important;
  }

  #InteractiveColumns-{{ section_id }} .column {
    height: var(--mobile-collapsed-h);
    border-radius: 0 !important;
  }
  #InteractiveColumns-{{ section_id }} .column:first-child {
    border-radius: var(--radius) var(--radius) 0 0 !important;
  }
  #InteractiveColumns-{{ section_id }} .column:last-child {
    border-radius: 0 0 var(--radius) var(--radius) !important;
  }

  #InteractiveColumns-{{ section_id }} .column.expanded {
    height: var(--mobile-expanded-h) !important;
  }

  #InteractiveColumns-{{ section_id }} .inner-element {
    bottom: auto;
    top: 0;
    opacity: 0;
    max-width: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,.55), rgba(0,0,0,0));
  }

  #InteractiveColumns-{{ section_id }} .inner-element.active {
    opacity: 1;
  }

  #InteractiveColumns-{{ section_id }} .icons {
    bottom: 12px;
  }
}

/* Accessibility helpers */
#InteractiveColumns-{{ section_id }} .visually-hidden {
  position:absolute;
  width:1px;
  height:1px;
  padding:0;
  margin:-1px;
  overflow:hidden;
  clip:rect(0 0 0 0);
  white-space:nowrap;
  border:0;
}
</style>

<script>
(function() {
  var root = document.getElementById('InteractiveColumns-{{ section_id }}');
  if (!root) return;

  var columns = Array.prototype.slice.call(root.querySelectorAll('[data-column]'));
  var triggers = Array.prototype.slice.call(root.querySelectorAll('[data-column-trigger]'));

  function collapseAll() {
    columns.forEach(function(col) {
      col.classList.remove('expanded');
      var inner = col.querySelector('.inner-element');
      if (inner) inner.classList.remove('active');
      var btn = col.querySelector('[data-column-trigger]');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  }

  function expand(col) {
    var inner = col.querySelector('.inner-element');
    var btn = col.querySelector('[data-column-trigger]');
    col.classList.add('expanded');
    if (inner) inner.classList.add('active');
    if (btn) btn.setAttribute('aria-expanded', 'true');
  }

  triggers.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var col = btn.closest('[data-column]');
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      if (isOpen) return; // keep one open
      collapseAll();
      expand(col);
    });

    btn.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        btn.click();
      }
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        var idx = triggers.indexOf(btn);
        var next = triggers[(idx + 1) % triggers.length];
        next.focus();
      }
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        var idx2 = triggers.indexOf(btn);
        var prev = triggers[(idx2 - 1 + triggers.length) % triggers.length];
        prev.focus();
      }
    });
  });

  // Ensure one open
  if (columns.length) {
    collapseAll();
    expand(columns[0]);
    }
})();
  </script>
{% schema %}
{
  "name": "Interactive Columns",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore"
    },
    {
      "type": "range",
      "id": "desktop_expanded_percent",
      "label": "Expanded width (desktop %)",
      "min": 35,
      "max": 75,
      "step": 1,
      "default": 55
    },
    {
      "type": "range",
      "id": "mobile_collapsed_height",
      "label": "Mobile collapsed height (px)",
      "min": 60,
      "max": 240,
      "step": 10,
      "default": 120
    },
    {
      "type": "range",
      "id": "mobile_expanded_height",
      "label": "Mobile expanded height (px)",
      "min": 200,
      "max": 800,
      "step": 20,
      "default": 420
    },
    {
      "type": "range",
      "id": "transition_duration",
      "label": "Transition duration (ms)",
      "min": 150,
      "max": 1200,
      "step": 50,
      "default": 500
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add descriptive text here."
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon / Short text",
          "default": "+"
        },
        {
          "type": "text",
          "id": "link_label",
            "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Interactive Columns",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}