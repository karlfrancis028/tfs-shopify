{{ 'section-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-faq.js' | asset_url }}" defer></script>

<div
  class="faq"
  data-faq
  style="background-color: {{ section.settings.background_color }};"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="faq__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="faq__layout">
    <nav class="faq__nav" aria-label="FAQ categories">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <button
            type="button"
            class="faq__nav-item"
            data-target="{{ block.id }}"
          >
            {{ block.settings.label }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="faq__content">
      {%- assign in_cat = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- if in_cat -%}</div>{%- endif -%}
          <div class="faq__category" data-cat="{{ block.id }}">
          {%- assign in_cat = true -%}
        {%- elsif block.type == 'question' -%}
          <details class="faq__item">
            <summary>{{ block.settings.question }}</summary>
            <div class="faq__answer">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
      {%- if in_cat -%}</div>{%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQs" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#DFE6E2" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "label", "label": "Category label", "default": "Category" }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "category" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
