      <textarea class="dossier-input" id="q27-other-text-{{ section.id }}" name="attributes[BF_Q27_Attitude_Other]" rows="3" placeholder="Please explain..." style="margin-top: 15px; display: none;"></textarea>
    </div>

    <!-- SLIDE 37: Q28 RECOLLECTION (PDF 100) -->
    <div class="dossier-slide" data-step="37">
      <img src="https://placehold.co/200x300/e0e0e0/173f2f?text=IMG:+Boy+on+Bike+(PDF+p.100)" class="dossier-slide-img" alt="Recollection">
      <h1 class="dossier-title">Does he have a cherished recollection from his early years?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q28_Recollection_Status]" value="Yes" id="q28-yes-radio-{{ section.id }}" required> Yes. When he was young...</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q28_Recollection_Status]" value="Cannot recall"> I can't recall any as of the moment.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q28_Recollection_Status]" value="Prefer not to answer"> I prefer not to answer.</label>
      </div>
      <textarea class="dossier-input" id="q28-yes-text-{{ section.id }}" name="attributes[BF_Q28_Recollection_Text]" rows="4" placeholder="Please share..." style="margin-top: 15px; display: none;"></textarea>
    </div>

    <!-- SLIDE 38: Q29 ROLE MODEL (PDF 101) -->
    <div class="dossier-slide" data-step="38">
      <img src="https://placehold.co/200x400/e0e0e0/173f2f?text=IMG:+Balloon+(PDF+p.101)" class="dossier-slide-img" alt="Role Model">
      <h1 class="dossier-title">Is there a person whose character he has long looked up to?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q29_RoleModel_Status]" value="Yes" id="q29-yes-radio-{{ section.id }}" required> Actually, there is someone...</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q29_RoleModel_Status]" value="None"> None in mind.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q29_RoleModel_Status]" value="Prefer not to answer"> I prefer not to answer.</label>
      </div>
      <textarea class="dossier-input" id="q29-yes-text-{{ section.id }}" name="attributes[BF_Q29_RoleModel_Text]" rows="4" placeholder="Please share..." style="margin-top: 15px; display: none;"></textarea>
    </div>

    <!-- SLIDE 39: Q30 EXPECTATION (PDF 102) -->
    <div class="dossier-slide" data-step="39">
      <img src="https://placehold.co/300x300/e0e0e0/173f2f?text=IMG:+Travel+Gear+(PDF+p.102)" class="dossier-slide-img" alt="Expectations">
      <h1 class="dossier-title">What do you expect on your friend's first box?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Discovering new" required> Discovering new brands/products he wouldn't pick.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Trusted classics"> Having trusted classics and essentials delivered.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Surprise & exclusivity"> The element of surprise & the level of exclusivity.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Enhance lifestyle"> Items that enhance his lifestyle (coffee, spirits, barware, etc.)</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Curiosity & learning"> A collection of items that supports his natural curiosity.</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q30_Expectation]" value="Other" id="q30-other-radio-{{ section.id }}"> I have something else in mind...</label>
      </div>
      <textarea class="dossier-input" id="q30-other-text-{{ section.id }}" name="attributes[BF_Q30_Expectation_Other]" rows="3" placeholder="Please explain..." style="margin-top: 15px; display: none;"></textarea>
    </div>

    <!-- ================= FINAL SLIDE: OUTRO (PDF 62) ================= -->
    <div class="dossier-slide" data-step="40">
      <div style="text-align: center; padding: 40px 0;">
        <h1 class="dossier-title" style="margin-bottom: 30px;">Thank you,<br><span id="final-name-placeholder">[Benefactor]</span>.</h1>
        <p class="dossier-subtitle" style="max-width: 500px; margin: 0 auto 30px;">With your permission, we will now translate your answers into a subscription experience tailored exclusively to your friend's lifestyle, taste, and ambition.</p>
        <p style="font-style: italic;">The Fortunate Son ensures that when his box arrives, it does not merely contain - it confirms who he is.</p>
      </div>
    </div>

    <!-- REQUIRED HIDDEN INPUTS -->
    <input type="hidden" name="attributes[survey_benefactors-note_completed]" value="true">
    <input type="hidden" name="attributes[Survey_Type]" value="The Benefactor's Note">

  </form>

  <!-- NAVIGATION -->
  <div class="dossier-nav">
    <button id="prevBtn-{{ section.id }}" class="dossier-btn dossier-btn-prev">Previous</button>
    <button id="nextBtn-{{ section.id }}" class="dossier-btn dossier-btn-next">Next</button>
  </div>
  <div id="dossier-status-message-{{ section.id }}" class="dossier-status"></div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // --- CONFIGURATION ---
  let currentStep = 1;
  const sectionId = "{{ section.id }}";
  const container = document.getElementById(`shopify-section-${sectionId}`);
  const slides = container.querySelectorAll('.dossier-slide');
  const totalSteps = slides.length;
  
  // --- ELEMENTS ---
  const nextBtn = document.getElementById(`nextBtn-${sectionId}`);
  const prevBtn = document.getElementById(`prevBtn-${sectionId}`);
  const form = document.getElementById(`dossier-form-${sectionId}`);
  const progressBar = document.getElementById(`progress-bar-${sectionId}`);
  const statusMessage = document.getElementById(`dossier-status-message-${sectionId}`);
  const oathCheckbox = document.getElementById(`oath-agreement-checkbox-${sectionId}`);
  const finalNamePlaceholder = document.getElementById('final-name-placeholder');
  // *** MODIFIED: This now points to the BENEFACTOR'S name ***
  const nameInput = container.querySelector('input[name="attributes[Benefactor_FullName]"]');

  // --- UI UPDATE FUNCTION ---
  function updateUI() {
    // Show current slide, hide others
    slides.forEach(slide => {
      if (parseInt(slide.dataset.step) === currentStep) {
        slide.classList.add('active');
      } else {
        slide.classList.remove('active');
      }
    });

    // Update Progress Bar
    const progress = (currentStep / totalSteps) * 100;
    progressBar.style.width = `${progress}%`;

    // Update Buttons Visibility/Text
    prevBtn.style.visibility = currentStep === 1 ? 'hidden' : 'visible';
    
    if (currentStep === totalSteps) {
        nextBtn.innerText = 'Submit Note';
        if (nameInput && finalNamePlaceholder) {
           // Extract first name for personalization
           const firstName = nameInput.value.split(' ')[0];
           finalNamePlaceholder.innerText = firstName || 'Benefactor';
        }
    } else if (currentStep === 2) {
        nextBtn.innerText = 'I Agree & Continue';
        // Enforce Oath Checkbox on Step 2
        nextBtn.disabled = !oathCheckbox.checked;
    } else {
        nextBtn.innerText = 'Next';
        nextBtn.disabled = false;
    }
    
    // Hide status message when moving between slides
    statusMessage.style.display = 'none';
  }

  // --- EVENT LISTENERS ---

  // Oath Checkbox Toggle
  if (oathCheckbox) {
    oathCheckbox.addEventListener('change', function() {
      if (currentStep === 2) {
        nextBtn.disabled = !this.checked;
      }
    });
  }

  // "Other" Radio/Text Area Logic
  // Supports both single-line inputs and multi-line textareas for "Other"
  function setupToggle(triggerSelector, targetId, triggerValue = 'Other') {
      const triggers = container.querySelectorAll(triggerSelector);
      const target = document.getElementById(targetId);
      if (triggers.length && target) {
          triggers.forEach(t => {
              t.addEventListener('change', () => {
                  if (t.type === 'radio') {
                      const checked = container.querySelector(`${triggerSelector}:checked`);
                      // Check specifically for value OR label content if needed, standardizing on value here.
                      target.style.display = (checked && checked.value === triggerValue) ? 'block' : 'none';
                      // Make required if visible
                      target.required = (target.style.display === 'block');
                  } else if (t.type === 'checkbox') {
                       target.style.display = t.checked ? 'block' : 'none';
                       target.required = t.checked;
                  } else if (t.type === 'select-one') {
                       target.style.display = (t.value === triggerValue) ? 'block' : 'none';
                       target.required = (t.value === triggerValue);
                  }
              });
          });
      }
  }

  // Apply toggles to all relevant questions
  setupToggle('input[name="attributes[BF_Q3_Frame]"]', `q3-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q7_HairColor]"]', `q7-other-text-${sectionId}`);
  setupToggle('select[name="attributes[BF_Q10_Ethnicity]"]', `q10-self-describe-${sectionId}`, 'Prefer to self-describe');
  setupToggle('input[name="attributes[BF_Q11_DailyWorld]"]', `q11-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q12_Weekend]"]', `q12-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q20_SocialRole]"]', `q20-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q21_Statement]"]', `q21-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q22_Excitement]"]', `q22-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q24_Color]"]', `q24-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q25_Activity_Other_Check]"]', `q25-other-check-${sectionId}`, 'Yes');
  setupToggle('input[name="attributes[BF_Q26_Space]"]', `q26-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q27_Attitude]"]', `q27-other-text-${sectionId}`);
  setupToggle('input[name="attributes[BF_Q28_Recollection_Status]"]', `q28-yes-text-${sectionId}`, 'Yes');
  setupToggle('input[name="attributes[BF_Q29_RoleModel_Status]"]', `q29-yes-text-${sectionId}`, 'Yes');
  setupToggle('input[name="attributes[BF_Q30_Expectation]"]', `q30-other-text-${sectionId}`);

  // --- HEIGHT UNIT TOGGLE ---
  const heightUnitSelect = document.getElementById(`height-unit-select-${sectionId}`);
  const heightCmInput = container.querySelector('.height-cm');
  const heightFtInContainer = container.querySelector('.height-ft-in');

  if (heightUnitSelect) {
    heightUnitSelect.addEventListener('change', function() {
       if (this.value === 'ft/in') {
           heightCmInput.style.display = 'none';
           heightCmInput.required = false;
           heightFtInContainer.style.display = 'flex';
           heightFtInContainer.querySelectorAll('input').forEach(i => i.required = true);
       } else {
           heightCmInput.style.display = 'block';
           heightCmInput.required = true;
           heightFtInContainer.style.display = 'none';
           heightFtInContainer.querySelectorAll('input').forEach(i => i.required = false);
       }
    });
  }

  // --- LIMIT CHECKBOXES ---
  container.querySelectorAll('.limit-checkboxes').forEach(list => {
      const limit = parseInt(list.dataset.limit);
      const boxes = list.querySelectorAll('input[type="checkbox"]');
      boxes.forEach(box => box.addEventListener('change', () => {
          if (list.querySelectorAll('input:checked').length >= limit) {
              boxes.forEach(b => { if (!b.checked) b.disabled = true; });
          } else {
              boxes.forEach(b => b.disabled = false);
          }
      }));
  });

  // --- NAVIGATION & SUBMIT ---
  function isStepValid() {
    const currentSlide = container.querySelector(`.dossier-slide[data-step="${currentStep}"]`);
    // Select all inputs that have the 'required' attribute AND are currently visible
    const requiredInputs = Array.from(currentSlide.querySelectorAll('[required]')).filter(input => {
        // Check if element is visible (offsetParent is null if hidden)
        return input.offsetParent !== null;
    });
    
    let valid = true;
    for (let input of requiredInputs) {
      if (!input.checkValidity()) {
        input.reportValidity(); // Shows the browser's built-in error bubble
        valid = false;
        break; // Stop at the first invalid field
      }
    }
    return valid;
  }

  nextBtn.addEventListener('click', function() {
    if (!isStepValid()) return;
    if (currentStep < totalSteps) {
      currentStep++;
      updateUI();
      window.scrollTo(0, 0);
    } else {
      submitDossier(); // Final step reached
    }
  });

  prevBtn.addEventListener('click', function() {
    if (currentStep > 1) {
      currentStep--;
      updateUI();
      window.scrollTo(0, 0);
    }
  });

  // --- AJAX SUBMIT FUNCTION ---
  function submitDossier() {
    // 1. Lock UI
    nextBtn.innerText = 'Submitting...';
    nextBtn.disabled = true;
    prevBtn.disabled = true;
    statusMessage.style.display = 'none';

    // 2. Send Data to Shopify Cart API
    fetch('/cart/update.js', {
      method: 'POST',
      body: new FormData(form)
    })
    .then(response => response.json())
    .then(data => {
      // 3. Success! Redirect to cart.
      window.location.href = '/cart';
    })
    .catch(error => {
      // 4. Handle Errors
      console.error('Error saving dossier:', error);
      statusMessage.className = 'dossier-status error';
      statusMessage.innerText = 'There was an issue saving your dossier. Please try again.';
      statusMessage.style.display = 'block';
      
      // Unlock UI
      nextBtn.innerText = 'Submit Note';
      nextBtn.disabled = false;
      prevBtn.disabled = false;
    });
  }

  // --- INITIALIZE ---
  updateUI();
});
</script>

{% schema %}
  {
    "name": "Benefactor's Note Survey",
    "settings": [],
    "presets": [{ "name": "Benefactor's Note Survey" }]
  }
{% endschema %}