{% comment %}
  SECTION: The Benefactor's Note (Final Complete Version)
  - All 30 Questions from PDF (rephrased for a friend).
  - Full PDF Design (Typography, Layout).
  - Background color for immersive feel.
{% endcomment %}

<style>
  /* --- SECTION BACKGROUND --- */
  #shopify-section-{{ section.id }} {
    background-color: #fcfcf8; /* Subtle off-white 'paper' color */
    padding: 60px 0;
  }

  /* --- GLOBAL & TYPOGRAPHY --- */
  #shopify-section-{{ section.id }} .dossier-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px;
    color: #173f2f;
    font-family: 'Garamond', 'Baskerville', 'Times New Roman', serif;
    background-color: #ffffff;
    box-shadow: 0 4px 30px rgba(0,0,0,0.03);
    border-radius: 2px;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .dossier-page {
      padding: 20px 20px 100px;
      box-shadow: none;
      background-color: transparent;
    }
  }
  /* Utility for form fields */
  #shopify-section-{{ section.id }} .sans-serif {
    font-family: 'Glacial Indifference', 'Helvetica', 'Arial', sans-serif;
  }

  /* --- IMAGES --- */
  #shopify-section-{{ section.id }} .dossier-slide-img {
    display: block;
    max-width: 180px;
    max-height: 180px;
    margin: 0 auto 25px;
    height: auto;
  }
  #shopify-section-{{ section.id }} .dossier-header-img {
    max-width: 120px;
    margin-bottom: 30px;
  }

  /* --- TEXT STYLES --- */
  #shopify-section-{{ section.id }} .dossier-title {
    font-size: 2.4rem;
    text-align: center;
    margin-bottom: 15px;
    line-height: 1.1;
    color: #173f2f;
    font-weight: normal;
  }
  #shopify-section-{{ section.id }} .dossier-subtitle {
    text-align: center;
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 35px;
    font-family: 'Glacial Indifference', sans-serif;
    line-height: 1.5;
  }
  #shopify-section-{{ section.id }} .dossier-section-header {
    text-align: center;
    padding: 100px 0;
  }
  #shopify-section-{{ section.id }} .dossier-section-kicker {
     text-transform: uppercase;
     letter-spacing: 4px;
     opacity: 0.7;
     font-size: 0.9rem;
     margin-bottom: 20px;
     font-family: sans-serif;
  }

  /* --- PROGRESS BAR --- */
  #shopify-section-{{ section.id }} .dossier-progress {
    height: 4px;
    background-color: #e0e0e0;
    margin-bottom: 40px;
    border-radius: 2px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .dossier-progress-bar {
    height: 100%;
    background-color: #173f2f;
    width: 0%;
    transition: width 0.5s ease;
  }

  /* --- SLIDES --- */
  #shopify-section-{{ section.id }} .dossier-slide {
    display: none;
    animation: fadeIn 0.6s ease;
  }
  #shopify-section-{{ section.id }} .dossier-slide.active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- FORM FIELDS --- */
  #shopify-section-{{ section.id }} .dossier-field {
    margin-bottom: 25px;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .dossier-label {
    display: block;
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 8px;
    color: #173f2f;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  #shopify-section-{{ section.id }} .dossier-input {
    width: 100%;
    padding: 14px;
    font-size: 1rem;
    border: 2px solid #e0e0e0;
    border-radius: 4px;
    background-color: #fcfcf8;
    font-family: sans-serif;
    transition: border-color 0.2s;
  }
  #shopify-section-{{ section.id }} .dossier-input:focus {
    outline: none;
    border-color: #173f2f;
    background-color: #fff;
  }
  #shopify-section-{{ section.id }} .dossier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dossier-grid {
      grid-template-columns: 1fr;
    }
  }


  /* --- COMPLEX INPUTS (Units) --- */
  #shopify-section-{{ section.id }} .input-with-unit {
    display: flex;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .input-with-unit .dossier-input {
    flex: 2;
  }
  #shopify-section-{{ section.id }} .input-unit-select {
    flex: 1;
    padding: 14px;
    font-size: 1rem;
    border: 2px solid #e0e0e0;
    border-radius: 4px;
    background-color: #eee;
    cursor: pointer;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .dual-input-container {
    display: flex;
    gap: 10px;
    flex: 2;
  }
  #shopify-section-{{ section.id }} .dual-input-container .dossier-input {
    flex: 1;
  }

  /* --- RADIO & CHECKBOX LISTS --- */
  #shopify-section-{{ section.id }} .option-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 100%;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .option-label {
    display: flex;
    align-items: center;
    padding: 15px 20px;
    border: 2px solid #e0e0e0;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1.05rem;
    background-color: #fff;
    font-weight: 500;
  }
  #shopify-section-{{ section.id }} .option-label:hover {
    border-color: #173f2f;
  }
  #shopify-section-{{ section.id }} .option-label:has(input:checked) {
    background-color: #173f2f;
    border-color: #173f2f;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .option-label input {
    margin-right: 15px;
    width: 20px;
    height: 20px;
    accent-color: #173f2f;
  }
  #shopify-section-{{ section.id }} .option-label:has(input:checked) input {
     accent-color: #fff; 
  }

  /* --- RATING SCALE STYLES --- */
  #shopify-section-{{ section.id }} .rating-scale {
    display: flex;
    justify-content: space-between;
    max-width: 500px;
    margin: 30px auto;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .rating-option {
    position: relative;
    width: 60px;
    height: 60px;
  }
  #shopify-section-{{ section.id }} .rating-option input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 100%;
    width: 100%;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .rating-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border: 2px solid #173f2f;
    border-radius: 6px;
    font-size: 1.5rem;
    font-weight: bold;
    color: #173f2f;
    transition: all 0.2s;
    background: #fff;
  }
  #shopify-section-{{ section.id }} .rating-option input:checked + .rating-box {
    background-color: #173f2f;
    color: white;
  }
  #shopify-section-{{ section.id }} .rating-labels {
    display: flex;
    justify-content: space-between;
    max-width: 500px;
    margin: -20px auto 30px;
    font-size: 0.9rem;
    color: #666;
    font-style: italic;
    font-family: sans-serif;
  }

  /* --- OATH BOX --- */
  #shopify-section-{{ section.id }} .oath-agreement-box {
    margin: 30px 0;
    padding: 25px;
    background-color: #f4f7f5;
    border-left: 6px solid #173f2f;
    border-radius: 8px;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .oath-agreement-box label {
    display: flex;
    align-items: flex-start;
    font-size: 1.05rem;
    line-height: 1.5;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .oath-agreement-box input {
    margin-right: 15px;
    width: 24px;
    height: 24px;
    margin-top: 3px;
    accent-color: #173f2f;
  }

  /* --- NAVIGATION --- */
  #shopify-section-{{ section.id }} .dossier-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 60px;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }
  #shopify-section-{{ section.id }} .dossier-btn {
    padding: 14px 35px;
    font-size: 1.1rem;
    font-weight: bold;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dossier-btn-next {
    background-color: #173f2f;
    color: white;
    margin-left: auto;
  }
  #shopify-section-{{ section.id }} .dossier-btn-next:hover:not(:disabled) {
    background-color: #0e281e;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(23, 63, 47, 0.2);
  }
  #shopify-section-{{ section.id }} .dossier-btn-prev {
    background-color: #e0e0e0;
    color: #333;
  }
  #shopify-section-{{ section.id }} .dossier-btn-prev:hover:not(:disabled) {
    background-color: #d0d0d0;
  }
  #shopify-section-{{ section.id }} .dossier-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none !important;
    box-shadow: none !important;
  }

  /* --- STATUS MESSAGES --- */
  #shopify-section-{{ section.id }} .dossier-status {
    margin-top: 20px;
    padding: 15px;
    border-radius: 6px;
    font-weight: 500;
    text-align: center;
    display: none;
    font-family: sans-serif;
  }
  #shopify-section-{{ section.id }} .dossier-status.error {
    background-color: #ffebee;
    color: #c62828;
    border: 1px solid #ef9a9a;
  }
</style>

<div class="dossier-page">
  
  <div class="dossier-progress">
    <div class="dossier-progress-bar" id="progress-bar-{{ section.id }}"></div>
  </div>

  <form id="dossier-form-{{ section.id }}">
    
    <!-- SLIDE 1: WELCOME (PDF 66) -->
    <div class="dossier-slide active" data-step="1">
      <img src="{{ 'The Fortunate Son Icon v1.png' | asset_url }}" class="dossier-header-img dossier-slide-img" alt="TFS Logo">
      <h1 class="dossier-title">For the discerning few.<br>A gesture of intent.</h1>
      <p class="dossier-subtitle">Think of this as your private note to us, detailing the character of a fortunate son. Your answers will guide a personally appointed box.</p>
    </div>

    <!-- SLIDE 2: THE OATH (PDF 62) -->
    <div class="dossier-slide" data-step="2">
      <h1 class="dossier-title">The Oath of Discretion</h1>
      <p class="dossier-subtitle">"What you share here becomes the blueprint of his world. Your answers remain confidential, used solely to ensure a thoughtfully assembled box."</p>
      <div class="oath-agreement-box">
        <label>
          <input type="checkbox" id="oath-agreement-checkbox-{{ section.id }}" required>
          <span><b>I agree</b> to the collection and use of this personal information for order processing and personalization. I have read the Privacy Notice.</span>
        </label>
      </div>
    </div>

    <!-- SLIDE 3: BENEFACTOR & FRIEND DOSSIER -->
    <div class="dossier-slide" data-step="3">
      <h1 class="dossier-title">The Benefactor & The Recipient</h1>
      <p class="dossier-subtitle">Please provide your details as the benefactor, and the name of the recipient.</p>
      <div class="dossier-field"><label class="dossier-label">Your Full Name</label><input type="text" class="dossier-input" name="attributes[Benefactor_FullName]" placeholder="Your First and Last Name" required></div>
      <div class="dossier-field"><label class="dossier-label">Your Email Address</label><input type="email" class="dossier-input" name="attributes[Benefactor_Email]" placeholder="Your Email" required></div>
      <hr style="border:none; border-top: 1px solid #eee; margin: 30px 0;">
      <div class="dossier-field"><label class="dossier-label">Your Friend's Full Name</label><input type="text" class="dossier-input" name="attributes[Friend_FullName]" placeholder="Recipient's First and Last Name" required></div>
      <div class="dossier-field"><label class="dossier-label">Your Friend's Date of Birth</label><input type="date" class="dossier-input" name="attributes[Friend_DOB]" required></div>
    </div>

    <!-- SLIDE 4: SECTION 1 HEADER (PDF 67) -->
    <div class="dossier-slide" data-step="4">
      <div class="dossier-section-header">
        <div class="dossier-section-kicker">Section 1</div>
        <h1 class="dossier-title">His Precise Details<br>for Form & Fit</h1>
      </div>
    </div>

    <!-- SLIDE 5: Q1 HEIGHT (PDF 68) - DUAL INPUT -->
    <div class="dossier-slide" data-step="5">
      <img src="https://placehold.co/300x300/e0e0e0/173f2f?text=IMG:+Tower+(PDF+p.68)" class="dossier-slide-img" alt="Tower">
      <h1 class="dossier-title">How tall does your friend stand?</h1>
      <div class="dossier-field input-with-unit height-unit-toggle">
        <!-- Single input for CM -->
        <input type="number" class="dossier-input height-cm" name="attributes[BF_Q1_Height_CM]" placeholder="Height in cm" required>
        <!-- Dual inputs for FT/IN (Initially hidden by JS) -->
        <div class="dual-input-container height-ft-in" style="display:none;">
           <input type="number" class="dossier-input" name="attributes[BF_Q1_Height_FT]" placeholder="Feet">
           <input type="number" class="dossier-input" name="attributes[BF_Q1_Height_IN]" placeholder="Inches">
        </div>
        <select class="input-unit-select" id="height-unit-select-{{ section.id }}" name="attributes[BF_Q1_Height_Unit]">
          <option value="cm">cm</option>
          <option value="ft/in">ft/in</option>
        </select>
      </div>
    </div>

    <!-- SLIDE 6: Q2 WEIGHT (PDF 69) -->
    <div class="dossier-slide" data-step="6">
      <img src="https://placehold.co/300x300/e0e0e0/173f2f?text=IMG:+Scale+(PDF+p.69)" class="dossier-slide-img" alt="Scale">
      <h1 class="dossier-title">How much does your friend weigh?</h1>
      <div class="dossier-field input-with-unit">
        <input type="number" class="dossier-input" name="attributes[BF_Q2_Weight_Value]" placeholder="Weight" required>
        <select class="input-unit-select" name="attributes[BF_Q2_Weight_Unit]"><option value="kg">kg</option><option value="lbs">lbs</option></select>
      </div>
    </div>

    <!-- SLIDE 7: Q3 FRAME (PDF 70) -->
    <div class="dossier-slide" data-step="7">
      <h1 class="dossier-title">Which best reflects your friend's frame?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q3_Frame]" value="Slim" required> Slim</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q3_Frame]" value="Average"> Average</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q3_Frame]" value="Broad"> Broad</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q3_Frame]" value="Athletic"> Athletic</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q3_Frame]" value="Other" id="q3-other-radio-{{ section.id }}"> Other</label>
      </div>
      <input type="text" class="dossier-input" id="q3-other-text-{{ section.id }}" name="attributes[BF_Q3_Frame_Other]" placeholder="Please specify..." style="margin-top: 15px; display: none;">
    </div>

    <!-- SLIDE 8: Q4 MEASUREMENTS (PDF 71) -->
    <div class="dossier-slide" data-step="8">
      <img src="https://placehold.co/300x200/e0e0e0/173f2f?text=IMG:+Tape+(PDF+p.71)" class="dossier-slide-img" alt="Tape Measure">
      <h1 class="dossier-title">Kindly provide your friend's measurements.</h1>
      <div class="dossier-field"><label class="dossier-label">Chest</label><div class="input-with-unit"><input type="number" class="dossier-input" name="attributes[BF_Q4_Chest_Value]" required><select class="input-unit-select" name="attributes[BF_Q4_Chest_Unit]"><option>cm</option><option>in</option></select></div></div>
      <div class="dossier-field"><label class="dossier-label">Waist</label><div class="input-with-unit"><input type="number" class="dossier-input" name="attributes[BF_Q4_Waist_Value]" required><select class="input-unit-select" name="attributes[BF_Q4_Waist_Unit]"><option>cm</option><option>in</option></select></div></div>
      <div class="dossier-field"><label class="dossier-label">Inseam</label><div class="input-with-unit"><input type="number" class="dossier-input" name="attributes[BF_Q4_Inseam_Value]" required><select class="input-unit-select" name="attributes[BF_Q4_Inseam_Unit]"><option>cm</option><option>in</option></select></div></div>
    </div>

    <!-- SLIDE 9: Q5 SHOE SIZE (PDF 72) -->
    <div class="dossier-slide" data-step="9">
      <img src="https://placehold.co/300x200/e0e0e0/173f2f?text=IMG:+Shoe+(PDF+p.72)" class="dossier-slide-img" alt="Shoe">
      <h1 class="dossier-title">What is your friend's shoe size?</h1>
      <div class="dossier-field input-with-unit">
        <input type="text" class="dossier-input" name="attributes[BF_Q5_ShoeSize_Value]" required>
        <select class="input-unit-select" name="attributes[BF_Q5_ShoeSize_Unit]"><option>EU</option><option>US</option><option>UK</option></select>
      </div>
    </div>

    <!-- SLIDE 10: Q6 SKIN TONE (PDF 73) -->
    <div class="dossier-slide" data-step="10">
      <img src="https://placehold.co/200x300/e0e0e0/173f2f?text=IMG:+Painter+(PDF+p.73)" class="dossier-slide-img" alt="Painter">
      <h1 class="dossier-title">What is your friend's skin tone?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q6_SkinTone]" value="Fair" required> Fair</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q6_SkinTone]" value="Medium"> Medium</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q6_SkinTone]" value="Olive"> Olive</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q6_SkinTone]" value="Tan"> Tan</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q6_SkinTone]" value="Dark"> Dark</label>
      </div>
    </div>

    <!-- SLIDE 11: Q7 HAIR COLOR (PDF 74) -->
    <div class="dossier-slide" data-step="11">
      <img src="https://placehold.co/250x300/e0e0e0/173f2f?text=IMG:+Hair+(PDF+p.74)" class="dossier-slide-img" alt="Hair">
      <h1 class="dossier-title">What is your friend's hair color?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Black" required> Black</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Brown"> Brown</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Blonde"> Blonde</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Red"> Red</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Gray"> Gray</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q7_HairColor]" value="Other" id="q7-other-radio-{{ section.id }}"> Other</label>
      </div>
      <input type="text" class="dossier-input" id="q7-other-text-{{ section.id }}" name="attributes[BF_Q7_HairColor_Other]" placeholder="Please specify..." style="margin-top: 15px; display: none;">
    </div>

    <!-- SLIDE 12: Q8 EYE COLOR (PDF 75) -->
    <div class="dossier-slide" data-step="12">
      <img src="https://placehold.co/250x300/e0e0e0/173f2f?text=IMG:+Goggles+(PDF+p.75)" class="dossier-slide-img" alt="Eyes">
      <h1 class="dossier-title">What is your friend's eye color?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Brown" required> Brown</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Blue"> Blue</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Green"> Green</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Hazel"> Hazel</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Gray"> Gray</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q8_EyeColor]" value="Dark Brown"> Dark Brown</label>
      </div>
    </div>

    <!-- SLIDE 13: Q9 FACE SHAPE (PDF 76) -->
    <div class="dossier-slide" data-step="13">
      <img src="https://placehold.co/250x300/e0e0e0/173f2f?text=IMG:+Thinking+(PDF+p.76)" class="dossier-slide-img" alt="Face Shape">
      <h1 class="dossier-title">What is the shape of your friend's face?</h1>
      <div class="option-list">
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Oval" required> Oval</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Square"> Square</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Round"> Round</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Heart"> Heart</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Diamond"> Diamond</label>
        <label class="option-label"><input type="radio" name="attributes[BF_Q9_FaceShape]" value="Not sure"> Not sure</label>
      </div>
    </div>

    <!-- SLIDE 14: Q10 ETHNICITY (PDF 77) -->
    <div class="dossier-slide" data-step="14">
      <h1 class="dossier-title">Which best describes your friend's ethnic or cultural identity?</h1>
      <p class="dossier-subtitle">We honor heritage as much as individuality.</p>
      <div class="dossier-field">
         <select class="dossier-input" name="attributes[BF_Q10_Ethnicity]" required>
            <option value="" disabled selected>Select an option...</option>
            <option value="East Asian">East Asian</option>
            <option value="South Asian">South Asian</option>
            <option value="Southeast Asian">Southeast Asian</option>
            <option value="Middle Eastern">Middle Eastern</option>
            <option value="Black / African descent">Black / African descent</option>
            <option value="White / Caucasian">White / Caucasian</option>
            <option value="Hispanic / Latino">Hispanic / Latino</option>
            <option value="Native / Indigenous">Native / Indigenous</option>
            <option value="Mixed / Multi-ethnic">Mixed / Multi-ethnic</option>
            <option value="Prefer to self-describe">Prefer to self-describe</option>
            <option value="Prefer not to answer">Prefer not to answer</option>
