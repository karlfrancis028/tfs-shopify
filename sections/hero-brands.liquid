{{ 'section-hero-brands.css' | asset_url | stylesheet_tag }}

<div
  id="HeroBrands-{{ section.id }}"
  class="hero-brands"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="hero-brands__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-brands__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hero-brands__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="hero-brands__grid">
      {%- for block in section.blocks -%}
        <div
          class="hero-brands__card{% if block.settings.darken %} hero-brands__card--darken{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                widths: '100, 200, 400',
                sizes: '240px',
                alt: block.settings.image.alt | default: ''
            }}
          {%- elsif block.settings.asset_filename != blank -%}
            <img src="{{ block.settings.asset_filename | asset_url }}" alt="" loading="lazy">
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hero Brands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Makers and crafts featured this season—alongside signature pieces from The Fortunate Son, reflected in your pairing."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#DFE6E2"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "asset_filename",
          "label": "Theme asset filename (fallback, e.g. spinule.svg)",
          "info": "Used only if no Logo image is picked."
        },
        {
          "type": "checkbox",
          "id": "darken",
          "label": "Darken logo",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero brands",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
