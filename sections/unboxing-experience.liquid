{{ 'section-unboxing-experience.css' | asset_url | stylesheet_tag }}

<div
  class="unboxing"
  style="background-color: {{ section.settings.background_color }}; --unboxing-speed: {{ section.settings.scroll_speed | default: 40 }}s;"
>
  <div class="unboxing__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="unboxing__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="unboxing__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="unboxing__grid">
      {%- comment -%} First pass — real blocks (visible to AT) {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="unboxing__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900, 1200',
                sizes: '(min-width: 750px) 32vw, 100vw',
                alt: block.settings.image.alt | default: ''
            }}
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- comment -%} Second pass — duplicate for seamless loop, hidden from AT {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="unboxing__item" aria-hidden="true">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900, 1200',
                sizes: '(min-width: 750px) 32vw, 100vw',
                alt: ''
            }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Unboxing experience",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Unboxing Experience" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Those with discerning taste live with intention. Every choice considered, every detail purposeful." },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#EEEEEE" },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "s",
      "label": "Scroll duration",
      "info": "Lower = faster",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Unboxing experience",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
