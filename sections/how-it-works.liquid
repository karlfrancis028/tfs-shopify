{{ 'section-how-it-works.css' | asset_url | stylesheet_tag }}

<div
  class="how-it-works"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="how-it-works__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="how-it-works__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="how-it-works__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="how-it-works__steps">
      {%- for block in section.blocks -%}
        <div class="how-it-works__step" {{ block.shopify_attributes }}>
          <div class="how-it-works__icon">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', widths: '40, 80, 120', sizes: '40px', alt: '' }}
            {%- elsif block.settings.icon_asset != blank -%}
              <img src="{{ block.settings.icon_asset | asset_url }}" alt="" loading="lazy">
            {%- endif -%}
          </div>
          <h3 class="how-it-works__step-title">{{ block.settings.title }}</h3>
          <p class="how-it-works__step-body">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.link_text != blank or section.settings.button_label != blank -%}
    <div class="how-it-works__footer">
      {%- if section.settings.link_text != blank -%}
        <a class="how-it-works__link" href="{{ section.settings.link_url | default: '#' }}">
          {{ section.settings.link_text }} →
        </a>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="how-it-works__button" href="{{ section.settings.button_url | default: '#' }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "How it works",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How It Works" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A seamless three-step process—from induction to delivery." },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#DFE6E2" },
    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Begin your journey" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "TAKE THE OATH OF DISCRETION" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon image" },
        { "type": "text", "id": "icon_asset", "label": "Theme asset icon (fallback, e.g. icon-box.svg)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Step title" },
        { "type": "textarea", "id": "body", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
