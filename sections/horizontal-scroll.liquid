{{ 'section-horizontal-scroll.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-horizontal-scroll.js' | asset_url }}" defer></script>

<div
  class="h-scroll"
  data-h-scroll
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="h-scroll__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="h-scroll__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="h-scroll__subheading">{{ section.settings.subheading | newline_to_br }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="h-scroll__track" data-scroll-track>
      {%- for block in section.blocks -%}
        <div class="h-scroll__card" {{ block.shopify_attributes }}>
          <div class="h-scroll__card-image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 600, 900', sizes: '(min-width: 750px) 300px, 80vw', alt: block.settings.image.alt | default: block.settings.title }}
            {%- endif -%}
          </div>
          <div class="h-scroll__card-body">
            {%- if block.settings.title != blank -%}
              <h3 class="h-scroll__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <p class="h-scroll__card-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="h-scroll__card-body-text">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.link_text != blank or section.settings.button_label != blank -%}
    <div class="h-scroll__footer">
      {%- if section.settings.link_text != blank -%}
        <a class="h-scroll__link" href="{{ section.settings.link_url | default: '#' }}">
          {{ section.settings.link_text }} →
        </a>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="h-scroll__button" href="{{ section.settings.button_url | default: '#' }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="h-scroll__nav">
    <button class="h-scroll__arrow" data-scroll-prev aria-label="Scroll previous" type="button">&laquo;</button>
    <div class="h-scroll__progress">
      <div class="h-scroll__progress-bar" data-scroll-progress></div>
    </div>
    <button class="h-scroll__arrow" data-scroll-next aria-label="Scroll next" type="button">&raquo;</button>
  </div>
</div>

{% schema %}
{
  "name": "Horizontal scroll",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Section heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#EEEEEE" },
    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "link_text", "label": "Link text" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle (optional)" },
        { "type": "textarea", "id": "body", "label": "Description (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Horizontal scroll",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
