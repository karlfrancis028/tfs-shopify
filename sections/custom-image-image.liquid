{% schema %}
{
  "name": "Custom ImageImage Card",
  "settings": [
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "url",
      "id": "left_button_link",
      "label": "Left Button Link"
    },
    {
      "type": "text",
      "id": "left_button_text",
      "label": "Left Button Text"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Right Title",
      "default": "Lorem ipsum"
    },
    {
      "type": "text",
      "id": "right_content",
      "label": "Right Content",
      "default": "Lorem ipsum"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "url",
      "id": "right_button_link",
      "label": "Right Button Link"
    },
    {
      "type": "text",
      "id": "right_button_text",
      "label": "Right Button Text"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Font Size (px)",
      "min": 12,
      "max": 48,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "Content Font Size (px)",
      "min": 14,
      "max": 72,
      "step": 1,
      "default": 32
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Custom ImageImage Card"
    }
  ]
}
{% endschema %}

<section class="custom-media-section">
  <div class="custom-media-container">
    <div class="custom-media-cards">
      <div class="custom-media-card active">
        
        <!-- LEFT MEDIA -->
        <div class="custom-media-left">
          {%- if section.settings.left_image != blank -%}
            {%- liquid
              assign image_height = section.settings.left_image.width | divided_by: section.settings.left_image.aspect_ratio
            -%}
            {{ section.settings.left_image 
              | image_url: width: 3840 
              | image_tag: 
                width: section.settings.left_image.width, 
                height: image_height, 
                sizes: "100vw", 
                class: "custom-media-left-image" 
            }}
          {%- endif -%}
          {%- if section.settings.left_button_text != blank -%}
            <a href="{{ section.settings.left_button_link }}" class="custom-media-btn">{{ section.settings.left_button_text }}</a>
          {%- endif -%}
        </div>

        <!-- RIGHT CONTENT (split into text + image) -->
        <div class="custom-media-right">
          <div class="custom-media-right-top custom-media-text" style="text-align: {{ section.settings.text_alignment }};">
            <div class="custom-media-title" style="font-size: {{ section.settings.title_size }}px;">
              <p>{{ section.settings.right_title }}</p>
            </div>
            <div class="custom-media-content" style="font-size: {{ section.settings.content_size }}px;">
              <h1>{{ section.settings.right_content }}</h1>
            </div>
          </div>

          <div class="custom-media-right-bottom custom-media-image-container">
            {%- if section.settings.right_image != blank -%}
              {%- liquid
                assign right_image_height = section.settings.right_image.width | divided_by: section.settings.right_image.aspect_ratio
              -%}
              {{ section.settings.right_image 
                | image_url: width: 1920 
                | image_tag: 
                  width: section.settings.right_image.width, 
                  height: right_image_height, 
                  sizes: "100vw", 
                  class: "custom-media-right-image" 
              }}
            {%- endif -%}
          </div>

          {%- if section.settings.right_button_text != blank -%}
            <a href="{{ section.settings.right_button_link }}" class="custom-media-btn">{{ section.settings.right_button_text }}</a>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>
</section>

<style>
.custom-media-section {
  width: 100%;
}
.custom-media-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  justify-content: center;
  align-items: center;
}
.custom-media-cards {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-start;
  width: 100%;
  margin: 20px 0;
}
.custom-media-card {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: stretch;
  width: 100%;
  min-height: 400px;
  border: 1px solid #ccc;
  border-radius: 8px;
  overflow: hidden;
  gap: 12px;
}

/* LEFT */
.custom-media-left,
.custom-media-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}
.custom-media-left img,
.custom-media-right img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* RIGHT split */
.custom-media-right {
  display: flex;
  flex-direction: column;
}
.custom-media-right-top {
  flex: 1;
  padding: 20px;
}
.custom-media-right-bottom {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.custom-media-image-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* Buttons */
.custom-media-btn {
  position: absolute;
  bottom: 14px;
  padding: 8px 14px;
  background: #fff;
  border: 1px solid #444;
  border-radius: 4px;
  text-decoration: none;
  font-size: 14px;
}
.custom-media-left .custom-media-btn {
  left: 14px;
}
.custom-media-right .custom-media-btn {
  right: 14px;
}
</style>
