    "faq_main": {
      "type": "faq-section",
      "blocks": {
        "cat_general": {
          "type": "category",
          "settings": {
            "label": "General Information"
          }
        },
        "q_general_1": {
          "type": "question",
          "settings": {
            "question": "Who can subscribe to The Fortunate Son?",
            "answer": "<p>Our subscription service is available to individuals aged 18 years old and above. By subscribing, you confirm that you meet this requirement.</p>"
          }
        },
        "cat_cycle": {
          "type": "category",
          "settings": {
            "label": "Subscription & Cycle"
          }
        },
        "q_cycle_1": {
          "type": "question",
          "settings": {
            "question": "How does the subscription cycle work?",
            "answer": "<p>Subscriptions run on a rolling three-month cycle starting from the month you subscribe.</p>"
          }
        },
        "q_cycle_2": {
          "type": "question",
          "settings": {
            "question": "When will I receive my curated box?",
            "answer": "<p>Your box will be shipped during the third month of your subscription cycle.</p>"
          }
        },
        "q_cycle_3": {
          "type": "question",
          "settings": {
            "question": "Does my subscription automatically renew?",
            "answer": "<p>Yes. Subscriptions automatically renew for the next quarterly cycle unless you make changes or cancel within the allowed window.</p>"
          }
        },
        "cat_updown": {
          "type": "category",
          "settings": {
            "label": "Upgrading, Downgrading & Cancellation"
          }
        },
        "q_ud_1": {
          "type": "question",
          "settings": {
            "question": "Can I upgrade or downgrade my subscription?",
            "answer": "<p>Yes. You may upgrade or downgrade your plan within 7 days after your current cycle ends.</p>"
          }
        },
        "q_ud_2": {
          "type": "question",
          "settings": {
            "question": "Can I cancel my subscription?",
            "answer": "<p>Yes. You may stop the next cycle during the same 7-day window after your current cycle ends.</p>"
          }
        },
        "q_ud_3": {
          "type": "question",
          "settings": {
            "question": "What happens if I don't make any changes or cancellation?",
            "answer": "<p>If no action is taken during the adjustment period, your subscription will automatically continue into the next cycle.</p><p><strong>Example:</strong><br>Cycle runs February–April<br>Box ships in April<br>Changes or cancellation allowed May 1–7<br>Subscription renews automatically after May 7</p>"
          }
        },
        "cat_payments": {
          "type": "category",
          "settings": {
            "label": "Payments"
          }
        },
        "q_pay_1": {
          "type": "question",
          "settings": {
            "question": "What payment methods do you accept?",
            "answer": "<p>We accept credit cards: VISA, MasterCard, and AMEX.</p>"
          }
        },
        "q_pay_2": {
          "type": "question",
          "settings": {
            "question": "Will I be charged automatically?",
            "answer": "<p>Yes. By subscribing, you authorize recurring billing for each quarterly cycle.</p>"
          }
        },
        "q_pay_3": {
          "type": "question",
          "settings": {
            "question": "What happens if my payment fails?",
            "answer": "<p>Your subscription may be temporarily suspended until payment is successfully processed.</p>"
          }
        },
        "q_pay_4": {
          "type": "question",
          "settings": {
            "question": "Are payments refundable?",
            "answer": "<p>Subscription payments are non-refundable, except in cases involving damaged or incorrect items.</p>"
          }
        },
        "cat_box": {
          "type": "category",
          "settings": {
            "label": "Subscription Box Contents"
          }
        },
        "q_box_1": {
          "type": "question",
          "settings": {
            "question": "Are the garments custom-made?",
            "answer": "<p>No. Boxes contain Ready-to-Wear (RTW) pieces, not bespoke or made-to-measure garments.</p>"
          }
        },
        "q_box_2": {
          "type": "question",
          "settings": {
            "question": "Why do you collect measurements?",
            "answer": "<p>Measurements help us select the most suitable RTW size for you.</p>"
          }
        },
        "q_box_3": {
          "type": "question",
          "settings": {
            "question": "Do you offer alterations?",
            "answer": "<p>Alterations are not provided by The Fortunate Son.</p>"
          }
        },
        "cat_returns": {
          "type": "category",
          "settings": {
            "label": "Returns & Exchanges"
          }
        },
        "q_ret_1": {
          "type": "question",
          "settings": {
            "question": "Do you accept returns or exchanges?",
            "answer": "<p>Returns and exchanges are generally not accepted, except under specific conditions.</p><p><strong>Damaged or Incorrect Items</strong><br>Notify us within 7 days of delivery. Provide supporting photos. Our Customer Service/Valet Team will assist on a case-by-case basis.</p><p><strong>Fit Issues</strong><br>Fit concerns may be reviewed only if accurate measurements were submitted during onboarding. Customers may visit a local tailor, or get assistance at our partner store Tino Suits. Providing accurate measurements helps minimize fit issues.</p>"
          }
        },
        "cat_delivery": {
          "type": "category",
          "settings": {
            "label": "Delivery"
          }
        },
        "q_del_1": {
          "type": "question",
          "settings": {
            "question": "What should I do if my box hasn't arrived?",
            "answer": "<p>Please contact our Customer Service/Valet Team so we can coordinate with the courier and provide updates.</p>"
          }
        }
      },
